# Copy to `readiness/.env` and fill in. Never commit `.env`.
#
#   cp readiness/.env.example readiness/.env

# --- Postgres (Neon, RDS, local Docker, etc.) — required for mirror + job queue ---
# Use sslmode=require for hosted providers.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# --- Intervals.icu (planned workouts) — optional but needed for intervals-sync ---
# Either pair works:
INTERVALS_ATHLETE_ID=
INTERVALS_API_KEY=
# ATHLETE_ID=
# API_KEY=

# --- Optional: Python binary for launchd / scripts (default: python3 on PATH) ---
# READINESS_PYTHON=/opt/homebrew/bin/python3.13

# --- Optional: prepend to PATH for launchd scripts (dir containing `codex`, etc.) ---
# READINESS_EXTRA_PATH=$HOME/.local/bin
